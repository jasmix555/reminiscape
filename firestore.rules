rules_version = '2';

// Reminiscape Firestore security rules
// Data model:
//   users/{uid}      - one doc per user (doc id == auth uid)
//   memories/{id}    - auto-id docs, owned via createdBy.uid
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // The set of fields that changed in an update.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // For an array field, the only elements added OR removed must be the
    // caller's own uid. Lets a user add/remove themselves from someone
    // else's friends / friendRequests, but never touch other entries.
    function diffOnlySelf(field) {
      let before = (field in resource.data) ? resource.data[field] : [];
      let after  = (field in request.resource.data) ? request.resource.data[field] : [];
      return after.removeAll(before).hasOnly([request.auth.uid])
          && before.removeAll(after).hasOnly([request.auth.uid]);
    }

    // A third party may only edit the friends / friendRequests arrays of
    // another user's doc, and only with respect to their own uid.
    function isFriendEdit(targetUid) {
      return isSignedIn()
          && request.auth.uid != targetUid
          && changedKeys().hasOnly(['friends', 'friendRequests'])
          && diffOnlySelf('friends')
          && diffOnlySelf('friendRequests');
    }

    // ---- users ----
    match /users/{userId} {
      // Any signed-in user can read profiles (needed for search + friends).
      allow read: if isSignedIn();

      // You may only create your own profile (doc id == your uid).
      allow create: if isUser(userId);

      // Full control of your own profile; limited friend edits on others'.
      allow update: if isUser(userId) || isFriendEdit(userId);

      // Profiles are never deleted from the client.
      allow delete: if false;
    }

    // ---- memories ----
    match /memories/{memoryId} {
      // Readable if you created it, or its creator is in your friends list.
      allow read: if isSignedIn()
                  && (
                       resource.data.createdBy.uid == request.auth.uid
                       || resource.data.createdBy.uid in
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.friends
                     );

      // You may only create memories attributed to yourself.
      allow create: if isSignedIn()
                    && request.resource.data.createdBy.uid == request.auth.uid;

      // Only the creator may edit, and ownership cannot be reassigned.
      allow update: if isSignedIn()
                    && resource.data.createdBy.uid == request.auth.uid
                    && request.resource.data.createdBy.uid == request.auth.uid;

      // Only the creator may delete.
      allow delete: if isSignedIn()
                    && resource.data.createdBy.uid == request.auth.uid;
    }

    // Everything else is denied by default.
  }
}
